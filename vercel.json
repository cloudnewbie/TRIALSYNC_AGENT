{
  "version": 2,
  "builds": [
    {
      "src": "trialsync-app/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "trialsync-app/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "trialsync-app/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "trialsync-app/$1"
    }
  ]
}
